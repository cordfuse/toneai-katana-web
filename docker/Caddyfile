# Caddy site config — reverse-proxies to the ToneAI Kat app container.
#
# ToneAI Kat streams chat tokens over SSE backed by a replay buffer, so the
# reverse_proxy block MUST disable proxy buffering or the stream stalls:
#   flush_interval -1                    — flush each write immediately
#   header_down X-Accel-Buffering no     — tell any upstream proxy not to buffer
#   header_down Connection keep-alive    — hold the connection open
#
# For a PUBLIC domain (Let's Encrypt auto-TLS):
#   toneai.example.com {
#       reverse_proxy app:3000 {
#           flush_interval -1
#           header_down X-Accel-Buffering no
#           header_down Connection keep-alive
#       }
#   }
#
# For an INTERNAL hostname (Caddy's own self-signed CA — needed because
# Let's Encrypt can't validate .internal / .lan / .local domains):
#   `tls internal` tells Caddy to mint a cert from its built-in CA. Browsers
#   warn until you trust the Caddy root CA (at
#   /data/caddy/pki/authorities/local/root.crt inside the caddy container).

toneai.internal {
    tls internal
    reverse_proxy app:3000 {
        flush_interval -1
        header_down X-Accel-Buffering no
        header_down Connection keep-alive
    }
}
