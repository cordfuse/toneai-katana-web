# Copy to .env and fill in your values. docker-compose.yml + the prod variant
# both load this file via `env_file: [.env]`.
#
# IMPORTANT: .env is gitignored. Never commit your real keys.

# ─── Required ────────────────────────────────────────────────────────────────

# JWT signing secret for the per-device auth token. Anything ≥ 32 chars of
# entropy is fine. Generate one with:  openssl rand -hex 32
JWT_SECRET=change-me-to-32-or-more-random-chars

# At least ONE provider API key. The default CHATFRAME_PROVIDER below picks
# anthropic, so set ANTHROPIC_API_KEY unless you change the provider.
ANTHROPIC_API_KEY=

# ─── Optional: additional provider keys ──────────────────────────────────────
# token.js auto-detects which providers are usable based on what's set here.
# The UI's model picker shows only providers with a configured key.

# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# COHERE_API_KEY=
# PERPLEXITY_API_KEY=
# AI21_API_KEY=

# AWS Bedrock — needs all three. AWS_REGION defaults to us-east-1.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ─── Optional: local providers (OpenAI-compatible endpoints) ─────────────────
# These default to localhost — override only if you've moved the server.
# When running Chatframe in Docker, set these to host.docker.internal:<port>
# (see extra_hosts in docker-compose.yml) so the container can reach the
# bare-metal local server.

# OLLAMA_BASE_URL=http://localhost:11434/v1
# LLAMACPP_BASE_URL=http://localhost:8080/v1
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Web search — enables the globe toggle in the composer.
#
# Two backends are supported:
#   - Provider-native search (Anthropic web_search, Google grounding,
#     Perplexity Sonar) — no extra API key, lower latency, no third-party
#     hop. Only available when the active provider supports it.
#   - Tavily — uniform across providers but requires TAVILY_API_KEY and
#     adds a per-search cost.
#
# CHATFRAME_SEARCH_BACKEND controls the choice:
#   - auto (default): native when the provider supports it, Tavily otherwise
#   - native: only ever use provider-native (no search for unsupported providers)
#   - tavily: always use Tavily (requires TAVILY_API_KEY)
#
# The globe toggle appears whenever at least one backend is available for
# the active provider (i.e. native search OR a Tavily key, depending on
# CHATFRAME_SEARCH_BACKEND).
#
# CHATFRAME_SEARCH_BACKEND=auto
# TAVILY_API_KEY=

# ─── Optional: defaults ──────────────────────────────────────────────────────
# Each of these falls back to a sensible default if unset.

# Provider + model used when the user hasn't picked one (or when the kiosk
# model picker is hidden — see CHATFRAME_SHOW_MODEL_PICKER below).
# CHATFRAME_PROVIDER=anthropic
# CHATFRAME_MODEL=claude-sonnet-4-6

# Server-default system prompt. The user can override per-conversation
# in Settings unless the gear is hidden via CHATFRAME_SHOW_SETTINGS=0.
# CHATFRAME_SYSTEM_PROMPT=You are a helpful AI assistant.

# Default sampling temperature.
# CHATFRAME_TEMPERATURE=1.0

# Default UI language for first-time visitors. Once a user picks a language
# in Settings, their choice persists via cookie and overrides this default.
# Built-in: en, es, fr, de. Add more by dropping <configDir>/locales/<code>.json
# (see README "Internationalisation").
# CHATFRAME_LOCALE=en

# When the active UI locale is non-English, Chatframe auto-appends a one-line
# "Respond in <language>." instruction to the system prompt so the model
# replies in the picked language. Set this to 0 to opt out (mostly useful
# if your system prompt already handles language explicitly).
# CHATFRAME_LOCALE_HINT=1

# ─── Optional: kiosk-mode UI gates ───────────────────────────────────────────
# Set any to 0 to hide that control. Hidden ≠ disabled — the feature still
# runs server-side using whatever's configured. Mix and match for your
# deployment shape (embed widget, kiosk terminal, internal tool, etc.).

# CHATFRAME_SHOW_HEADER=0         # hide the entire top bar
# CHATFRAME_SHOW_HEADER_ICON=0    # hide just the app icon (header still renders)
# CHATFRAME_SHOW_HEADER_TITLE=0   # hide just the app name (header still renders)
# CHATFRAME_SHOW_SETTINGS=0       # hide the Settings gear
# CHATFRAME_PERSIST_CHAT=0        # disable localStorage chat history (no sidebar)
# CHATFRAME_SHOW_WEB_SEARCH=0     # hide globe; web search auto-on if TAVILY set
# CHATFRAME_SHOW_MCP=0            # hide MCP picker; all servers auto-enabled
# CHATFRAME_SHOW_MODEL_PICKER=0   # hide model pill; CHATFRAME_PROVIDER+MODEL forced
# CHATFRAME_SHOW_ATTACHMENTS=0    # hide the paperclip
# CHATFRAME_SHOW_VOICE_INPUT=0    # hide the mic button (STT via Web Speech API)
# CHATFRAME_SHOW_VOICE_OUTPUT=0   # hide the speaker toggle (TTS via Web Speech API)
