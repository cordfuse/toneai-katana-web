# Copy to .env and fill in your values. docker-compose.yml + the prod variant
# both load this file via `env_file: [.env]`.
#
# IMPORTANT: .env is gitignored. Never commit your real keys.

# ─── Required ────────────────────────────────────────────────────────────────

# JWT signing secret for the per-device auth token. Anything ≥ 32 chars of
# entropy is fine. Generate one with:  openssl rand -hex 32
JWT_SECRET=change-me-to-32-or-more-random-chars

# Anthropic API key for the free tier (server's own key, subject to the daily
# quota). Users can also bring their own key per-request (BYOK), which bypasses
# the quota. This app is Anthropic-only.
ANTHROPIC_API_KEY=

# ─── Optional: defaults ──────────────────────────────────────────────────────
# Each falls back to a sensible default if unset.

# The tone-design model (Sonnet-tier — needs reasoning). Must be an id in
# config/providers.yaml, which is the allow-list that validates it. Operator-only:
# the model spends this key on the free tier, so the client cannot choose it.
# TONEAI_MODEL=claude-sonnet-4-6

# Sampling temperature. Operator-only — no per-conversation override.
# TONEAI_TEMPERATURE=1.0

# Daily free-tier request limit, shared across all users (global pool).
# THIS IS THE BUDGET CAP: a served request costs ~$0.09 (measured), so 50/day is
# about $4.50/day. Raise it deliberately — it is the only thing bounding the bill.
# FREE_DAILY_LIMIT=50

# What ONE device may take from that pool per day — the fairness cap. Without it a
# single visitor (or script) can drain the whole day for everyone. Note device_id
# is a client-generated UUID, so this is a speed bump, not a wall.
# FREE_DEVICE_DAILY_LIMIT=5

# Max web searches the model may run per response. Searches bill to the server
# key on the free tier, so this is the per-request cost cap; FREE_DAILY_LIMIT x
# this value bounds the daily search ceiling. Clamped 1..10. Default 3.
# TONEAI_WEB_SEARCH_MAX_USES=3

# Default UI language for first-time visitors. Once a user picks a language
# in Settings, their choice persists via cookie and overrides this default.
# Built-in: en. Add more by dropping <configDir>/locales/<code>.json.
# TONEAI_LOCALE=en

# When the active UI locale is non-English, the app auto-appends a one-line
# "Respond in <language>." instruction to the system prompt. Set 0 to opt out.
# TONEAI_LOCALE_HINT=1
