  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && rm -rf .next/standalone/.next/static .next/standalone/public .next/standalone/config && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && cp -r config .next/standalone/config",
