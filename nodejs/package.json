    "@ai-sdk/groq": "^3.0.42",
    "@ai-sdk/mistral": "^3.0.40",
    "@ai-sdk/openai": "^3.0.74",
    "@ai-sdk/openai-compatible": "^2.0.51",
    "@ai-sdk/perplexity": "^3.0.36",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.209",
