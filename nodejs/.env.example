# ─── Recommended: set these as real environment variables ───────────────────
# Pass them via your container orchestrator (docker compose `environment:`,
# k8s Secrets, systemd `Environment=`, fly secrets, etc.). Real env vars are
# the smaller, safer surface — no file on disk to mount, rotate, or leak.
#
# For local dev convenience only, you may copy this file to .env.local and
# fill it in (gitignored). npm start loads .env.local via
# --env-file-if-exists; real env vars always win over file values, so the
# two coexist cleanly when both are present.

# ─── Required ────────────────────────────────────────────────────────────────

# JWT secret for signing device-auth tokens. Any random ≥32-char string.
# Generate: openssl rand -base64 32
JWT_SECRET=

# Anthropic API key for the free tier (the server's own key, subject to the
# daily quota). Users can also bring their own key per-request (BYOK), which
# bypasses the quota. This app is Anthropic-only.
ANTHROPIC_API_KEY=

# ─── Optional (defaults shown) ───────────────────────────────────────────────

# Default tone-design model. Needs real reasoning (web research + a constrained
# schema), so Sonnet-tier, not Opus. Must be an id in config/providers.yaml.
# Single source of truth for the default — drives client and server.
# TONEAI_MODEL=claude-sonnet-5

# Light model — for future light tasks (classification, short titling) that
# don't need deep reasoning. Haiku by default. Wired via lib/server/models.ts.
# TONEAI_MODEL_LIGHT=claude-haiku-4-5

# Default sampling temperature (users can override per-conversation).
# TONEAI_TEMPERATURE=1.0

# Daily free-tier request limit, shared across all users (global pool).
# FREE_DAILY_LIMIT=1000

# SQLite database path (device auth + quota + logs).
# DB_PATH=data/katana.db

# Default UI language for first-time visitors. Once a user picks a language in
# Settings, their choice persists via cookie and overrides this. Built-in: en.
# Add more by dropping <configDir>/locales/<code>.json.
# TONEAI_LOCALE=en

# When the active UI locale is non-English, the app appends a one-line
# "Respond in <language>." to the system prompt. Set 0 to opt out.
# TONEAI_LOCALE_HINT=1

# Where the app reads its runtime config (toneai.config.json, custom.css,
# icons/, locales/). Defaults to ./config.
# TONEAI_CONFIG_DIR=./config
# TONEAI_CONFIG_PATH=   # explicit path to a single config file (overrides DIR)
